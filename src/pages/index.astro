---
import 'bootstrap/dist/css/bootstrap.min.css';
import 'bootstrap-icons/font/bootstrap-icons.css';
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../assets/logo-nature.png';
import toba from '../assets/nature-toba.jpg';

// ============================================================
// DATA YANG SERING DIUBAH
// Ubah isi pada bagian ini untuk memperbarui konten website.
// Tidak perlu mengubah bagian HTML di bawah jika hanya mengganti teks.
// ============================================================

// Alamat formulir pendaftaran. Semua tombol "Gabung" memakai alamat ini.
const registrationUrl =
  'https://docs.google.com/forms/d/e/1FAIpQLSf8TGiAw-wUbm_OG9bWwzGSvICBt7h2Cdnxr6zoirLbCSncwg/viewform';

// Daftar program/kegiatan. Tambah atau hapus satu blok untuk mengubah kartu kegiatan.
const activities = [
  {
    icon: 'bi-heart-pulse',
    title: 'Ibadah Bulanan',
    text: 'Ruang untuk bertumbuh dalam iman melalui doa, pujian, renungan, dan persekutuan bersama.'
  },
  {
    icon: 'bi-trophy',
    title: 'Olahraga',
    text: 'Aktivitas olahraga bersama untuk menjaga kesehatan dan mempererat hubungan antaranggota.'
  },
  {
    icon: 'bi-stars',
    title: 'Perayaan Natal',
    text: 'Perayaan penuh syukur melalui ibadah, pujian, kebersamaan, dan pelayanan sosial.'
  },
  {
    icon: 'bi-music-note-beamed',
    title: 'Gondang Naposo',
    text: 'Perjumpaan generasi muda melalui musik, tarian, dan tradisi untuk menjaga budaya Batak.'
  }
];

// Nilai organisasi yang tampil pada bagian Tentang Kami.
const values = [
  ['bi-people', 'Kekeluargaan', 'Saling menghargai, merangkul, dan mendukung sebagai satu keluarga.'],
  ['bi-book', 'Iman', 'Bertumbuh bersama dengan nilai kerohanian sebagai landasan.'],
  ['bi-link-45deg', 'Kebersamaan', 'Aktif berpartisipasi dan bekerja sama dalam setiap kegiatan.'],
  ['bi-flower1', 'Budaya', 'Menjaga dan meneruskan identitas serta nilai luhur budaya Batak.'],
  ['bi-heart', 'Kepedulian', 'Peka terhadap kebutuhan anggota dan masyarakat sekitar.'],
  ['bi-shield-check', 'Integritas', 'Jujur, bertanggung jawab, dan dapat dipercaya.']
];

// Pengurus inti. Ganti "Nama ..." dengan nama pengurus yang sebenarnya.
const leaders = [
  ['Pembina', 'Nama Pembina'],
  ['Penasihat', 'Nama Penasihat'],
  ['Ketua', 'Nama Ketua'],
  ['Wakil Ketua', 'Nama Wakil Ketua'],
  ['Sekretaris', 'Nama Sekretaris'],
  ['Bendahara', 'Nama Bendahara']
];

// Daftar bidang organisasi. Nama koordinator masih menggunakan teks sementara.
const divisions = [
  'Kerohanian',
  'Adat & Budaya',
  'Olahraga',
  'Sosial',
  'Humas & Dokumentasi'
];

// Pertanyaan dan jawaban pada bagian FAQ.
const faqs = [
  ['Siapa yang boleh bergabung?', 'Naposobulung Sitorus, Boru, Bere, dan Ibebere yang berdomisili atau beraktivitas di wilayah Jabodetabek.'],
  ['Apakah harus bermarga Sitorus?', 'Tidak. Boru, Bere, dan Ibebere dari keluarga besar Sitorus juga dapat bergabung sesuai ketentuan organisasi.'],
  ['Apakah ada batas usia untuk bergabung?', 'Ketentuan usia mengikuti kebijakan resmi organisasi. Isi formulir terlebih dahulu agar pengurus dapat memberikan informasi lebih lanjut.'],
  ['Apakah ada iuran anggota?', 'Ketentuan iuran akan dijelaskan oleh pengurus setelah proses pendaftaran dan verifikasi.'],
  ['Apakah saya harus tinggal di Jakarta?', 'Tidak. Keanggotaan ditujukan bagi yang berdomisili atau aktif di wilayah Jabodetabek.'],
  ['Bagaimana cara mengikuti kegiatan?', 'Informasi jadwal dan lokasi kegiatan dibagikan melalui kanal komunikasi resmi organisasi.']
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Website resmi NATURE Jabodetabek, wadah Naposobulung Sitorus, Boru, Bere, dan Ibebere di wilayah Jabodetabek."
    />
    <meta name="theme-color" content="#a71120" />
    <meta property="og:title" content="NATURE Jabodetabek" />
    <meta property="og:description" content="Bersatu dalam kekeluargaan, bertumbuh dalam budaya." />
    <meta property="og:type" content="website" />
    <title>NATURE Jabodetabek</title>
  </head>
  <body>
    <!--
      NAVIGASI UTAMA
      href="#tentang" akan membawa pengunjung ke bagian yang memiliki id="tentang".
    -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav" aria-label="Navigasi utama">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="#beranda" aria-label="NATURE Jabodetabek">
          <Image src={logo} alt="" width={46} height={46} format="webp" class="nav-logo" />
          <span><strong>NATURE</strong><small>JABODETABEK</small></span>
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarMenu"
          aria-controls="navbarMenu"
          aria-expanded="false"
          aria-label="Buka navigasi"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMenu">
          <ul class="navbar-nav ms-auto align-items-lg-center">
            <li class="nav-item"><a class="nav-link" href="#tentang">Tentang</a></li>
            <li class="nav-item"><a class="nav-link" href="#kegiatan">Kegiatan</a></li>
            <li class="nav-item"><a class="nav-link" href="#struktur">Pengurus</a></li>
            <li class="nav-item"><a class="nav-link" href="#galeri">Galeri</a></li>
            <li class="nav-item"><a class="nav-link" href="#faq">FAQ</a></li>
            <li class="nav-item ms-lg-3">
              <a class="btn btn-light btn-sm px-3" href={registrationUrl} target="_blank" rel="noopener">
                Gabung Sekarang
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main>
      <!-- HERO: tampilan pertama yang dilihat pengunjung -->
      <section class="hero" id="beranda">
        <div class="hero-pattern" aria-hidden="true"></div>
        <div class="container position-relative">
          <div class="row align-items-center min-vh-100 py-5">
            <div class="col-lg-7 hero-copy">
              <span class="eyebrow">Horas! Selamat datang di</span>
              <h1>NATURE<br /><em>Jabodetabek</em></h1>
              <p class="hero-subtitle">Naposobulung Sitorus Boru Bere Jabodetabek</p>
              <p class="hero-tagline">Bersatu dalam kekeluargaan.<br />Bertumbuh dalam budaya.</p>
              <div class="d-flex flex-wrap gap-3 mt-4">
                <a class="btn btn-primary btn-lg" href={registrationUrl} target="_blank" rel="noopener">
                  Gabung Sekarang <i class="bi bi-arrow-up-right ms-2"></i>
                </a>
                <a class="btn btn-outline-light btn-lg" href="#kegiatan">
                  Lihat Kegiatan <i class="bi bi-arrow-down ms-2"></i>
                </a>
              </div>
            </div>
            <div class="col-lg-5 d-none d-lg-flex justify-content-center">
              <div class="hero-emblem">
                <Image
                  src={logo}
                  alt="Logo NATURE Jabodetabek"
                  width={480}
                  densities={[1, 2]}
                  format="webp"
                  loading="eager"
                />
              </div>
            </div>
          </div>
        </div>
        <a href="#tentang" class="scroll-cue" aria-label="Gulir ke bagian tentang">
          <span>Jelajahi</span><i class="bi bi-arrow-down"></i>
        </a>
      </section>

      <!-- TENTANG: deskripsi, visi, misi, dan nilai organisasi -->
      <section class="section about-section" id="tentang">
        <div class="container">
          <div class="row g-5 align-items-center">
            <div class="col-lg-6">
              <span class="section-kicker">Tentang Kami</span>
              <h2>Rumah untuk bertumbuh<br />dan berjalan bersama.</h2>
              <p class="lead">
                NATURE Jabodetabek adalah wadah kebersamaan Naposobulung Sitorus, Boru, Bere,
                dan Ibebere di Jakarta, Bogor, Depok, Tangerang, dan Bekasi.
              </p>
              <p>
                Berawal dari semangat generasi muda untuk memiliki ruang kebersamaan, NATURE
                hadir untuk mempererat hubungan kekeluargaan, menumbuhkan kepedulian, serta
                menjaga nilai budaya Batak melalui kegiatan kerohanian, olahraga, sosial, dan budaya.
              </p>
            </div>
            <div class="col-lg-6">
              <div class="vision-card">
                <span class="card-number">01</span>
                <h3>Visi Kami</h3>
                <p>
                  Menjadi wadah generasi muda Sitorus, Boru, Bere, dan Ibebere yang solid,
                  beriman, berbudaya, serta berdampak positif bagi anggota dan masyarakat.
                </p>
                <hr />
                <h3>Misi Kami</h3>
                <ul class="check-list">
                  <li>Mempererat persaudaraan dan rasa kekeluargaan.</li>
                  <li>Menumbuhkan iman dan karakter melalui persekutuan.</li>
                  <li>Melestarikan serta memperkenalkan budaya Batak.</li>
                  <li>Mengembangkan potensi anggota melalui kegiatan bersama.</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="values-grid mt-5 pt-lg-4">
            {values.map(([icon, title, text]) => (
              <article class="value-item">
                <i class={`bi ${icon}`}></i>
                <div>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- MAKNA LOGO: ganti teks sementara setelah penjelasan resmi tersedia -->
      <section class="section logo-section" id="makna-logo">
        <div class="container">
          <div class="row g-5 align-items-center">
            <div class="col-lg-5 text-center">
              <div class="logo-stage">
                <Image src={logo} alt="Lambang NATURE Jabodetabek" width={430} format="webp" />
              </div>
            </div>
            <div class="col-lg-7">
              <span class="section-kicker text-white-50">Identitas Kami</span>
              <h2>Makna di balik lambang.</h2>
              <p class="logo-intro">
                Setiap warna dan unsur membawa nilai yang menjadi bagian dari perjalanan NATURE.
              </p>
              <div class="meaning-list">
                <div><span class="color-dot red"></span><strong>Merah</strong><p>Semangat, keberanian, dan kekuatan.</p></div>
                <div><span class="color-dot white"></span><strong>Putih</strong><p>Ketulusan, kesucian, dan kejujuran.</p></div>
                <div><span class="color-dot black"></span><strong>Hitam</strong><p>Keteguhan, kebijaksanaan, dan wibawa.</p></div>
                <div><i class="bi bi-bezier2"></i><strong>Gorga & Huruf N</strong><p>Identitas budaya dan kesatuan NATURE.</p></div>
                <div><i class="bi bi-house-heart"></i><strong>Rumah Adat</strong><p>Rumah kebersamaan dan akar kekeluargaan.</p></div>
                <div><i class="bi bi-flower2"></i><strong>Tunas Bunga</strong><p>Harapan untuk terus tumbuh dan berkembang.</p></div>
              </div>
              <small class="content-note">Penjelasan sementara — akan disesuaikan dengan dokumen resmi.</small>
            </div>
          </div>
        </div>
      </section>

      <!-- KEGIATAN: isi kartu dibuat otomatis dari daftar activities di atas -->
      <section class="section activities-section" id="kegiatan">
        <div class="container">
          <div class="section-heading text-center mx-auto">
            <span class="section-kicker">Ruang Kebersamaan</span>
            <h2>Program & Kegiatan</h2>
            <p>Berjumpa, bertumbuh, dan merawat budaya melalui kegiatan yang bermakna.</p>
          </div>
          <div class="row g-4 mt-4">
            {activities.map((activity, index) => (
              <div class="col-md-6 col-xl-3">
                <article class="activity-card h-100">
                  <span class="activity-number">0{index + 1}</span>
                  <i class={`bi ${activity.icon}`}></i>
                  <h3>{activity.title}</h3>
                  <p>{activity.text}</p>
                  <span class="soon-label">Agenda segera hadir</span>
                </article>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- STRUKTUR: pengurus inti dan koordinator bidang -->
      <section class="section organization-section" id="struktur">
        <div class="container">
          <div class="section-heading text-center mx-auto">
            <span class="section-kicker">Pelayan Organisasi</span>
            <h2>Struktur Organisasi</h2>
            <p>Susunan sementara untuk kebutuhan tampilan. Data resmi akan segera diperbarui.</p>
          </div>
          <div class="org-chart mt-5">
            <div class="row justify-content-center g-3">
              {leaders.map(([role, name], index) => (
                <div class={index < 2 ? 'col-6 col-md-3' : 'col-6 col-md-4 col-lg-2'}>
                  <article class="person-card">
                    <div class="avatar"><i class="bi bi-person"></i></div>
                    <span>{role}</span>
                    <h3>{name}</h3>
                  </article>
                </div>
              ))}
            </div>
            <div class="divider-label"><span>Koordinator Bidang</span></div>
            <div class="row justify-content-center g-3">
              {divisions.map((division) => (
                <div class="col-6 col-md-4 col-lg">
                  <article class="division-card">
                    <i class="bi bi-people-fill"></i>
                    <span>Bidang</span>
                    <h3>{division}</h3>
                    <small>Nama Koordinator</small>
                  </article>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- GALERI: gambar utama tersedia, gambar kegiatan masih berupa placeholder -->
      <section class="section gallery-section" id="galeri">
        <div class="container">
          <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-5">
            <div>
              <span class="section-kicker">Cerita dalam Gambar</span>
              <h2 class="mb-0">Galeri Kegiatan</h2>
            </div>
            <p class="gallery-copy mb-0">Dokumentasi perjalanan dan momen kebersamaan kami.</p>
          </div>
          <div class="gallery-grid">
            <figure class="gallery-main">
              <Image src={toba} alt="Pemandangan Danau Toba dan lambang NATURE" width={1100} format="webp" />
              <figcaption><span>Identitas & Budaya</span><strong>NATURE Jabodetabek</strong></figcaption>
            </figure>
            {activities.map((activity) => (
              <div class="gallery-placeholder">
                <i class={`bi ${activity.icon}`}></i>
                <span>Dokumentasi</span>
                <strong>{activity.title}</strong>
                <small>Segera hadir</small>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CARA BERGABUNG: tombol membuka Google Forms di tab baru -->
      <section class="section join-section" id="bergabung">
        <div class="container">
          <div class="join-panel">
            <div class="row align-items-center g-5">
              <div class="col-lg-5">
                <span class="section-kicker text-white-50">Menjadi Bagian dari Kami</span>
                <h2>Mari bertumbuh<br />bersama NATURE.</h2>
                <p>
                  Isi formulir pendaftaran dan pengurus kami akan menghubungi kamu untuk proses selanjutnya.
                </p>
                <a class="btn btn-light btn-lg mt-3" href={registrationUrl} target="_blank" rel="noopener">
                  Isi Formulir Pendaftaran <i class="bi bi-arrow-up-right ms-2"></i>
                </a>
              </div>
              <div class="col-lg-7">
                <ol class="join-steps">
                  {[
                    'Isi formulir',
                    'Verifikasi pengurus',
                    'Dihubungi pengurus',
                    'Masuk grup WhatsApp',
                    'Ikuti kegiatan perdana',
                    'Resmi menjadi anggota'
                  ].map((step, index) => (
                    <li><span>{String(index + 1).padStart(2, '0')}</span>{step}</li>
                  ))}
                </ol>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ: pertanyaan dibuat otomatis dari daftar faqs di atas -->
      <section class="section faq-section" id="faq">
        <div class="container">
          <div class="row g-5">
            <div class="col-lg-4">
              <span class="section-kicker">Pertanyaan Umum</span>
              <h2>Yang sering ditanyakan.</h2>
              <p>Belum menemukan jawaban? Hubungi pengurus melalui kanal resmi kami.</p>
            </div>
            <div class="col-lg-8">
              <div class="accordion accordion-flush" id="faqAccordion">
                {faqs.map(([question, answer], index) => (
                  <div class="accordion-item">
                    <h3 class="accordion-header">
                      <button
                        class={`accordion-button ${index === 0 ? '' : 'collapsed'}`}
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target={`#faq-${index}`}
                        aria-expanded={index === 0 ? 'true' : 'false'}
                        aria-controls={`faq-${index}`}
                      >
                        {question}
                      </button>
                    </h3>
                    <div
                      id={`faq-${index}`}
                      class={`accordion-collapse collapse ${index === 0 ? 'show' : ''}`}
                      data-bs-parent="#faqAccordion"
                    >
                      <div class="accordion-body">{answer}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- FOOTER: ganti teks kontak setelah WhatsApp, Instagram, dan email resmi tersedia -->
    <footer>
      <div class="container">
        <div class="row g-5">
          <div class="col-lg-5">
            <a class="footer-brand d-flex align-items-center gap-3" href="#beranda">
              <Image src={logo} alt="" width={68} height={68} format="webp" />
              <span><strong>NATURE</strong><small>JABODETABEK</small></span>
            </a>
            <p class="mt-3">Naposobulung Sitorus Boru Bere Jabodetabek</p>
          </div>
          <div class="col-6 col-lg-3">
            <h2>Navigasi</h2>
            <a href="#tentang">Tentang Kami</a>
            <a href="#kegiatan">Kegiatan</a>
            <a href="#struktur">Struktur</a>
            <a href="#galeri">Galeri</a>
          </div>
          <div class="col-6 col-lg-4">
            <h2>Kontak</h2>
            <span><i class="bi bi-whatsapp"></i> WhatsApp segera hadir</span>
            <span><i class="bi bi-instagram"></i> Instagram segera hadir</span>
            <span><i class="bi bi-envelope"></i> Email segera hadir</span>
          </div>
        </div>
        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} NATURE Jabodetabek</span>
          <span>Dibangun untuk kebersamaan & budaya.</span>
        </div>
      </div>
    </footer>

    <button class="back-to-top" id="backToTop" type="button" aria-label="Kembali ke atas">
      <i class="bi bi-arrow-up"></i>
    </button>

    <script>
      // Memuat fungsi Bootstrap untuk menu mobile dan accordion FAQ.
      import 'bootstrap/dist/js/bootstrap.bundle.min.js';

      // Mengambil elemen yang akan diberi interaksi.
      const nav = document.querySelector('#mainNav');
      const backToTop = document.querySelector('#backToTop');
      const menu = document.querySelector('#navbarMenu');

      // Mengubah tampilan navbar saat halaman digulir dan menampilkan tombol "ke atas".
      const updateScrollState = () => {
        const scrolled = window.scrollY > 40;
        nav?.classList.toggle('scrolled', scrolled);
        backToTop?.classList.toggle('visible', window.scrollY > 500);
      };

      updateScrollState();
      window.addEventListener('scroll', updateScrollState, { passive: true });

      // Mengembalikan pengunjung ke bagian paling atas halaman.
      backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

      // Menutup menu mobile secara otomatis setelah salah satu menu dipilih.
      menu?.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', () => {
          const collapse = window.bootstrap?.Collapse.getInstance(menu);
          collapse?.hide();
        });
      });

      // Memberi tanda aktif pada menu sesuai bagian halaman yang sedang terlihat.
      const sections = document.querySelectorAll('main section[id]');
      const links = document.querySelectorAll('.navbar-nav .nav-link');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            links.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`);
            });
          });
        },
        { rootMargin: '-35% 0px -55%', threshold: 0 }
      );
      sections.forEach((section) => observer.observe(section));
    </script>
  </body>
</html>
